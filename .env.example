# Lyr Environment Configuration Example
# Copy this to .env and fill in your values

# Required: API key for authenticating requests
# Generate with: python -c "import secrets; print('lyr_' + secrets.token_hex(16))"
LYR_API_KEY=lyr_your_secure_key_here

# Optional: Environment (development or production)
LYR_ENVIRONMENT=development

# Optional: Server configuration
LYR_HOST=0.0.0.0
LYR_PORT=8000