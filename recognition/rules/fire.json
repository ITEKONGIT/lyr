          "history_window_seconds": 10,
          "required": true,
          "role": "corroborates",
          "weight": 0.1,
          "reason": "Low humidity corroborates heat risk"
        },
        {
          "sensor_id": "smoke_1",
          "sensor_type": "smoke",
          "operator": ">",
          "threshold": 0.5,
          "history_window_seconds": 5,
