      "sensor_type": "temperature",
      "enter_threshold": 36.0,
      "clear_threshold": 34.0,
      "severity": "warning",
      "mode": "log_only",
      "sustained_for_seconds": 0.0,
      "clear_delay_seconds": 0.0,
      "staleness_policy": "alert_stale",
      "stale_age_seconds": 600,
      "conditions": [
        {
          "sensor_id": "outdoor_temp",
          "sensor_type": "temperature",
          "operator": ">",
          "threshold": 35.0,
          "history_window_seconds": 600,
          "required": true,
          "role": "context",
          "weight": 0.0,
          "reason": "Outdoor heat explains elevated indoor temperature"
        },
        {
          "sensor_id": "smoke_1",
          "sensor_type": "smoke",
          "operator": "<=",
          "threshold": 0.1,
          "history_window_seconds": 60,
          "required": false,
          "role": "contradicts",
          "weight": 0.15,
          "reason": "No smoke lowers fire-like risk"
        }
      ],
      "metadata": {
        "phase": "2.7.6",
        "base_confidence": 0.5,
        "primary_weight": 0.1,
        "max_confidence": 0.9,
        "missing_required_penalty": 0.15,
        "stale_required_penalty": 0.15
      },
      "enabled": true
    }
  ]
